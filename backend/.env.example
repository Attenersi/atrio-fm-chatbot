NVIDIA_API_KEY=REPLACE_WITH_REAL_NVIDIA_API_KEY
NVIDIA_EMBED_API_KEY=REPLACE_WITH_REAL_NVIDIA_EMBED_API_KEY
LLM_MODEL=meta/llama-3.1-70b-instruct
EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

ADMIN_TOKEN=REPLACE_WITH_STRONG_ADMIN_TOKEN
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# Session auth
AUTH_SESSION_TTL_HOURS=8
AUTH_SESSION_COOKIE=fm_session
AUTH_BOOTSTRAP_USER_USERNAME=user
# Leave empty in production to skip creating a default user.
# Required only if you want a non-admin account auto-created on first start.
AUTH_BOOTSTRAP_USER_PASSWORD=REPLACE_WITH_STRONG_USER_PASSWORD

# Optional email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
ADMIN_NOTIFY_EMAIL=
MAIL_NOTIFY_NEW_TICKETS=all

# Optional: override browser CORS allowlist (regex). Default allows only localhost / 127.0.0.1.
# To allow LAN or *.local hosts, set this explicitly, e.g.:
# CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|192\.168\.\d{1,3}\.\d{1,3}|[a-zA-Z0-9.-]+\.local)(:\d+)?$

# Auth cookie hardening for production behind HTTPS.
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=strict

# LLM and rate limit tuning (defaults are sensible for dev).
# LLM_TIMEOUT_SECONDS=60
# LLM_HEALTH_TIMEOUT_SECONDS=5
# RATE_LIMIT_CHAT=30/minute
# RATE_LIMIT_EMBED=60/minute

# Hard cap on outbound NVIDIA RPM (chat + embed + analyzer + eval all share
# this single token bucket). NVIDIA's account-wide limit is 40 RPM; we leave
# 5 as buffer. Lower this if you start seeing 429s from NVIDIA.
# NVIDIA_RPM_BUDGET=35

# Faza D: prompt analyzer (training quality panel). LLM_ANALYZER_MODEL falls
# back to LLM_MODEL by default. For better suggestions try a stronger NIM model
# (e.g. meta/llama-3.3-70b-instruct or nvidia/llama-3.3-nemotron-super-49b-v1).
# LLM_ANALYZER_MODEL=meta/llama-3.3-70b-instruct
# ANALYZER_MAX_GROUPS=4
# ANALYZER_MAX_EXAMPLES_PER_GROUP=5
# ANALYZER_CACHE_TTL_HOURS=24

# Faza E: prompt override safeguards.
# MAX_ACTIVE_OVERRIDES=5
# OVERRIDE_MIN_CONFIDENCE=0.5
# EVAL_BASELINE_MAX_AGE_HOURS=24

# OpenAI-compatible LLM API (any vendor). Prefer LLM_*; NVIDIA_* names still work.
LLM_API_KEY=REPLACE_WITH_LLM_API_KEY
LLM_EMBED_API_KEY=
# Admin → LLM / Models profiles: keep real secrets in backend/.env (gitignored), not in tickets.db.
# Create a profile with the API key field empty and set Env alias to LLM_API_KEY to use this value at runtime.
# For a second vendor, add e.g. LLM_API_KEY_VENDOR_B=... and set that profile's Env alias to LLM_API_KEY_VENDOR_B.
# Pasting a key in the admin form stores ciphertext in SQLite instead; see LLM_PROFILES_SECRET below.
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# Legacy aliases (optional if LLM_* above are set):
# NVIDIA_API_KEY=
# NVIDIA_EMBED_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

LLM_MODEL=meta/llama-3.1-70b-instruct
# Default 0.2. Moonshot Kimi K2.5/K2.6: Instant (thinking disabled) + 0.6 / top_p 0.95 in llm.py; Thinking + 1.0 via extra_body thinking.type (see llm.py).
# LLM_TEMPERATURE=1
EMBED_MODEL=nvidia/llama-nemotron-embed-1b-v2

ADMIN_TOKEN=REPLACE_WITH_STRONG_ADMIN_TOKEN
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# Session auth
AUTH_SESSION_TTL_HOURS=8
AUTH_SESSION_COOKIE=fm_session
AUTH_BOOTSTRAP_USER_USERNAME=user
# Leave empty in production to skip creating a default user.
# Required only if you want a non-admin account auto-created on first start.
AUTH_BOOTSTRAP_USER_PASSWORD=REPLACE_WITH_STRONG_USER_PASSWORD

# Strip obvious instruction-like lines from uploaded FM docs before indexing (default: true).
# Set to false only if legitimate docs are falsely redacted.
# DOCS_SANITIZE_INSTRUCTION_LIKE=true

# Optional email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
ADMIN_NOTIFY_EMAIL=
MAIL_NOTIFY_NEW_TICKETS=all

# Optional: override browser CORS allowlist (regex). Default allows only localhost / 127.0.0.1.
# To allow LAN or *.local hosts, set this explicitly, e.g.:
# CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|192\.168\.\d{1,3}\.\d{1,3}|[a-zA-Z0-9.-]+\.local)(:\d+)?$

# Auth cookie hardening for production behind HTTPS.
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=strict

# LLM and rate limit tuning (defaults are sensible for dev).
# LLM_TIMEOUT_SECONDS=60
# LLM_HEALTH_TIMEOUT_SECONDS=5
# Training-quality analyzer: LLM attempts/timeouts (defaults sized so wait_for does not cut off early).
# ANALYZER_MAX_LLM_ATTEMPTS=2
# ANALYZER_LLM_TIMEOUT_SECONDS=120
# ANALYZER_REPAIR_BUDGET_SECONDS=120
# ANALYZER_DEADLINE_SECONDS=450
# RATE_LIMIT_CHAT=30/minute
# RATE_LIMIT_EMBED=60/minute

# Hard cap on outbound LLM RPM (chat + embed + analyzer + eval share this bucket).
# Legacy: NVIDIA_RPM_BUDGET
# LLM_RPM_BUDGET=35
# Retries when the provider returns HTTP 429 (waits between attempts; exponential backoff).
# Legacy: NVIDIA_429_RETRY_ATTEMPTS, NVIDIA_429_RETRY_BASE_SECONDS
# LLM_429_RETRY_ATTEMPTS=5
# LLM_429_RETRY_BASE_SECONDS=10

# RAG: how many Chroma chunks are kept after reranking for each chat turn (restart to apply).
# RAG_TOP_K=3
# Ingest text splitter defaults for Chroma (admin UI can override per reindex/upload).
# INGEST_CHUNK_SIZE=1200
# INGEST_CHUNK_OVERLAP=150
# Optional: comma-separated extra env var NAMES to show in GET /api/admin/llm/chat-target
# → env_api_key_diag.candidates (presence only; never read by the app unless you use them as profile Env alias).
# FM_LLM_DIAG_EXTRA_ENV_KEYS=MY_OTHER_LLM_API_KEY

# Faza D: prompt analyzer (training quality panel). LLM_ANALYZER_MODEL falls
# back to LLM_MODEL by default. For better suggestions try a stronger NIM model
# (e.g. meta/llama-3.3-70b-instruct or nvidia/llama-3.3-nemotron-super-49b-v1).
# LLM_ANALYZER_MODEL=meta/llama-3.3-70b-instruct
# ANALYZER_MAX_GROUPS=4
# ANALYZER_MAX_EXAMPLES_PER_GROUP=5
# ANALYZER_CACHE_TTL_HOURS=24
# Max completion tokens for analyzer JSON (raise if you see truncated JSON / parse errors).
# ANALYZER_MAX_OUTPUT_TOKENS=3072

# Faza E: prompt override safeguards.
# MAX_ACTIVE_OVERRIDES=5
# OVERRIDE_MIN_CONFIDENCE=0.5
# EVAL_BASELINE_MAX_AGE_HOURS=24

# Admin UI: LLM profiles — metadata is always in SQLite; API keys are either env_alias
# (points at a server env var) or an encrypted blob when you paste in the form.
# Encrypted paste: set LLM_PROFILES_SECRET and restart (inline keys are then allowed by default).
# Env-only: leave the form API key empty; set Env alias (e.g. LLM_API_KEY).
# To block pasting even when LLM_PROFILES_SECRET is set: ALLOW_INLINE_LLM_KEYS=false
# LLM_PROFILES_SECRET=use_a_long_random_secret_string
# ALLOW_INLINE_LLM_KEYS=false

# Chat prompt-injection guards (see docs/prompt_injection_and_guardrails.md).
# CHAT_INJECTION_REGEX_ENABLED=true
# conservative (default) | strict — strict adds higher false-positive patterns.
# CHAT_INJECTION_REGEX_MODE=conservative
# Second LLM gate (extra latency/cost); unknown classifier output fails open unless FAIL_CLOSED.
# CHAT_INJECTION_LLM_FILTER=false
# CHAT_INJECTION_LLM_FILTER_FAIL_CLOSED=false
# LLM_INJECTION_FILTER_MODEL=meta/llama-3.1-8b-instruct
# LLM_INJECTION_FILTER_TIMEOUT_SECONDS=12
# LLM_INJECTION_FILTER_MAX_TOKENS=12
# CHAT_INJECTION_CANNED_RESPONSE=
# Optional comma-separated substrings to flag in assistant response text (case-insensitive).
# CHAT_OUTPUT_SENSITIVE_TERMS=
